# --- Option A: Anthropic API directly (recommended) ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_CHAT_MODEL=claude-3-5-haiku-20241022   # optional, this is the default

# --- Option B: OpenRouter (or any OpenAI-compatible provider) ---
# OPENAI_API_KEY=your_openrouter_key_here
# OPENAI_API_BASE=https://openrouter.ai/api/v1
# OPENAI_CHAT_MODEL=anthropic/claude-3.5-haiku

# OpenTelemetry — set automatically by docker-compose, override here if needed
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=code-review-demo
