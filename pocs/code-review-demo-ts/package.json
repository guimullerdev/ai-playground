{
  "name": "code-review-demo-ts",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "playwright test"
  },
  "vitest": {
    "include": [
      "tests/**/*.test.ts"
    ],
    "coverage": {
      "provider": "v8",
      "reporter": [
        "text",
        "lcov"
      ],
      "include": [
        "src/core/**"
      ]
    }
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.85",
    "@hono/node-server": "^1.0.0",
    "@types/ws": "^8.18.1",
    "beeai-framework": "latest",
    "dotenv": "^16.0.0",
    "hono": "^4.0.0",
    "uuid": "^14.0.0",
    "ws": "^8.21.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.9"
  }
}
