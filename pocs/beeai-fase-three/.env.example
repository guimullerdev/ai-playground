# Backend selection: openrouter (default) or claude-code
BACKEND=openrouter

# OpenRouter — get your free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Free model to use (see https://openrouter.ai/models?q=free for the full list)
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
